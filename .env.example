# Frontend Environment Variables
VITE_API_URL=http://localhost:3200
VITE_WS_URL=ws://localhost:3200
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_ENVIRONMENT=development

# Support
SUPPORT_PHONE=800123456

# ================================================
# IMPORTANTE: Configurazioni API
# ================================================
# Le seguenti configurazioni NON vanno più nel .env
# ma devono essere configurate dal pannello admin:
#
# 1. WhatsApp (SendApp Cloud)
#    -> /admin/api-keys/whatsapp
#
# 2. Google Maps 
#    -> /admin/api-keys/google-maps
#
# 3. Brevo (Email)
#    -> /admin/api-keys/brevo
#
# 4. OpenAI
#    -> /admin/api-keys/openai
#
# 5. Stripe
#    -> /admin/api-keys/stripe (quando implementato)
#
# Tutte le API Keys sono salvate nel database
# nella tabella ApiKey e gestite dall'interfaccia
# ================================================
