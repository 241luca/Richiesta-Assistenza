# ==============================================
# WHATSAPP INTEGRATION - SENDAPP
# ==============================================

# SendApp Access Token
# Ottieni dal pannello: https://app.sendapp.cloud
SENDAPP_TOKEN=your_sendapp_token_here

# SendApp API URL (default: https://app.sendapp.cloud/api)
SENDAPP_URL=https://app.sendapp.cloud/api

# Webhook URL per ricevere messaggi (opzionale)
# Deve essere un URL pubblico HTTPS
SENDAPP_WEBHOOK_URL=https://yourdomain.com/api/whatsapp/webhook

# Instance ID Default (opzionale)
# Viene generato automaticamente se non specificato
# SENDAPP_INSTANCE_ID=

# ==============================================
# DATABASE
# ==============================================

DATABASE_URL="postgresql://assistenza_user:assistenza_secure_password@localhost:5434/assistenza_db"

# Password per PostgreSQL Docker (dev/local)
DB_PASSWORD=assistenza_secure_password
DB_USER=assistenza_user
DB_NAME=assistenza_db

# ==============================================
# JWT & SECURITY
# ==============================================

JWT_SECRET=your_jwt_secret_min_32_chars
SESSION_SECRET=your_session_secret_min_32_chars

# ==============================================
# REDIS (opzionale ma consigliato)
# ==============================================

REDIS_URL=redis://:redis_secure_password@localhost:6382
REDIS_PASSWORD=redis_secure_password

# ==============================================
# EMAIL SERVICE
# ==============================================

BREVO_API_KEY=your_brevo_api_key

# ==============================================
# GOOGLE SERVICES
# ==============================================

GOOGLE_MAPS_API_KEY=your_google_maps_key

# ==============================================
# SMARTDOCS INTEGRATION
# ==============================================

SMARTDOCS_ENABLED=true
SMARTDOCS_API_URL=http://localhost:3500
SMARTDOCS_API_KEY=

# ==============================================
# AI SERVICES (opzionale)
# ==============================================

OPENAI_API_KEY=your_openai_key

# ==============================================
# PAYMENT (opzionale)
# ==============================================

STRIPE_SECRET_KEY=your_stripe_secret_key

# ==============================================
# APP SETTINGS
# ==============================================

NODE_ENV=development
PORT=3200
LOG_LEVEL=info

# ==============================================
# MONITORING (opzionale)
# ==============================================

SENTRY_DSN=your_sentry_dsn
