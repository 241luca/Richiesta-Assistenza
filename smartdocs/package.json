{
  "name": "@smartdocs/api",
  "version": "0.1.0",
  "description": "SmartDocs - AI-powered Document Management System (Standalone Service)",
  "main": "dist/index.js",
  "author": "Mario Rossi <mario.rossi@assistenza.it>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "ts-node src/worker.ts",
    "admin": "cd admin-ui && node server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write 'src/**/*.{ts,json}'",
    "db:init": "psql $DATABASE_URL -f scripts/init-db.sql",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f smartdocs-api",
    "docker:rebuild": "docker-compose down && docker-compose up -d --build"
  },
  "dependencies": {
    "@types/minio": "^7.1.0",
    "axios": "^1.6.2",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "mammoth": "^1.6.0",
    "mime-types": "^2.1.35",
    "minio": "^8.0.6",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.2",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "document-management",
    "ai",
    "rag",
    "embeddings",
    "classification",
    "extraction",
    "ocr",
    "nlp"
  ]
}
