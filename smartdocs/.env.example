# ⚠️ IMPORTANTE: Variabili ambiente SmartDocs
# Questo è un servizio SEPARATO dal backend Richiesta Assistenza

# Node Environment
NODE_ENV=development
PORT=3500

# ============================================================================
# DATABASE (SEPARATO da Richiesta Assistenza)
# ⚠️ Database SmartDocs su porta 5433, NON tocca DB principale (5432)
# ============================================================================
DATABASE_URL=postgresql://smartdocs:smartdocs_secure_pwd@localhost:5433/smartdocs

# ============================================================================
# REDIS (Caching & Job Queue)
# ============================================================================
REDIS_URL=redis://:smartdocs_redis_pwd@localhost:6380

# ============================================================================
# AI PROVIDERS
# ============================================================================

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORG_ID=

# Alternative AI Providers (opzionale)
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
OLLAMA_ENDPOINT=http://localhost:11434

# ============================================================================
# STORAGE (MinIO S3-compatible)
# ============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=smartdocs
MINIO_SECRET_KEY=smartdocs_minio_password
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# AWS S3 (se usi S3 reale)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_BUCKET=

# ============================================================================
# VECTOR DATABASE
# ============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================================
# EXTERNAL API (Comunicazione con Richiesta Assistenza)
# ⚠️ UNICO PUNTO DI CONTATTO tra i due sistemi
# ============================================================================
RICHIESTA_ASSISTENZA_API_URL=http://localhost:5000/api
RICHIESTA_ASSISTENZA_API_KEY=your-api-key-here

# ============================================================================
# PROCESSING SETTINGS
# ============================================================================

# Chunking
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200

# Concurrency
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_MS=300000

# File limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,md,html,xlsx,xls,csv,json

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/smartdocs.log

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_RATE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:5193,http://localhost:3000

# ============================================================================
# MONITORING (opzionale)
# ============================================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ===========================================
# SmartDocs Configuration
# ===========================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Security
ENCRYPTION_KEY=change-this-to-a-32-char-key-here

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5193,http://localhost:3000,http://localhost:3501

# Worker Configuration
WORKER_POLL_INTERVAL=5000

# MinIO Storage (optional, defaults used if not set)
MINIO_ACCESS_KEY=smartdocs
MINIO_SECRET_KEY=smartdocs_minio_password
MINIO_BUCKET=documents

# Database (configured in docker-compose.yml)
# DATABASE_URL=postgresql://smartdocs:smartdocs_secure_pwd@localhost:5433/smartdocs

# Redis (configured in docker-compose.yml)
# REDIS_URL=redis://:smartdocs_redis_pwd@localhost:6380
