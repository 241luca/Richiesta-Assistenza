// Schema for SQLite - Local Development
// This is a simplified version for testing without Docker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS (as String for SQLite) ====================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  plan        String   @default("BASIC") // BASIC, PROFESSIONAL, ENTERPRISE
  isActive    Boolean  @default(true)
  settings    String?  // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users               User[]
  categories          Category[]
  assistanceRequests  AssistanceRequest[]
  quotes              Quote[]
  payments            Payment[]
  notifications       Notification[]

  @@index([slug])
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  username          String   @unique
  password          String
  firstName         String
  lastName          String
  fullName          String
  phone             String?
  role              String   @default("CLIENT") // SUPER_ADMIN, ADMIN, PROFESSIONAL, CLIENT
  
  // Profile
  avatar            String?
  bio               String?
  
  // Italian fiscal data
  codiceFiscale     String?
  partitaIva        String?
  ragioneSociale    String?
  pec               String?
  sdi               String?
  
  // Address
  address           String?
  city              String?
  province          String?
  postalCode        String?
  country           String   @default("IT")
  
  // Professional data
  profession        String?
  specializations   String?  // JSON array
  hourlyRate        Float?
  currency          String   @default("EUR")
  serviceAreas      String?  // JSON array
  
  // Security
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  emailVerified     Boolean  @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  loginAttempts     Int      @default(0)
  lockedUntil       DateTime?
  
  // Relations
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  clientRequests      AssistanceRequest[] @relation("ClientRequests")
  professionalRequests AssistanceRequest[] @relation("ProfessionalRequests")
  quotes              Quote[]
  payments            Payment[]
  sentNotifications   Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  loginHistory        LoginHistory[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([organizationId])
  @@index([role])
}

model Category {
  id                String   @id @default(uuid())
  name              String
  slug              String
  description       String?
  icon              String?
  color             String   @default("#3B82F6")
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  subcategories     Subcategory[]
  assistanceRequests AssistanceRequest[]
  depositRules      DepositRule[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Subcategory {
  id                String   @id @default(uuid())
  name              String
  slug              String
  description       String?
  requirements      String?
  
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  
  assistanceRequests AssistanceRequest[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
}

model AssistanceRequest {
  id                String   @id @default(uuid())
  title             String
  description       String
  priority          String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status            String   @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  
  // Location
  address           String?
  city              String?
  province          String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  
  // Scheduling
  requestedDate     DateTime?
  assignedDate      DateTime?
  completedDate     DateTime?
  
  // Relations
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  clientId          String
  client            User @relation("ClientRequests", fields: [clientId], references: [id])
  
  professionalId    String?
  professional      User? @relation("ProfessionalRequests", fields: [professionalId], references: [id])
  
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  
  subcategoryId     String?
  subcategory       Subcategory? @relation(fields: [subcategoryId], references: [id])
  
  quotes            Quote[]
  attachments       Attachment[]
  payments          Payment[]
  
  metadata          String?  // JSON string
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([professionalId])
  @@index([categoryId])
  @@index([status])
}

model Quote {
  id                String   @id @default(uuid())
  title             String
  description       String?
  totalAmount       Float
  currency          String   @default("EUR")
  status            String   @default("DRAFT") // DRAFT, PENDING, ACCEPTED, REJECTED, EXPIRED
  validUntil        DateTime?
  notes             String?
  termsConditions   String?
  isSelected        Boolean  @default(false)
  version           Int      @default(1)
  
  // Relations
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  requestId         String
  request           AssistanceRequest @relation(fields: [requestId], references: [id])
  
  professionalId    String
  professional      User @relation(fields: [professionalId], references: [id])
  
  items             QuoteItem[]
  payments          Payment[]
  
  metadata          String?  // JSON string
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([requestId])
  @@index([professionalId])
  @@index([status])
}

model QuoteItem {
  id                String   @id @default(uuid())
  description       String
  quantity          Float    @default(1)
  unitPrice         Float
  totalPrice        Float
  taxRate           Float    @default(0.22)
  taxAmount         Float    @default(0)
  discount          Float    @default(0)
  displayOrder      Int      @default(1)
  notes             String?
  
  quoteId           String
  quote             Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now())

  @@index([quoteId])
}

model Payment {
  id                String   @id @default(uuid())
  amount            Float
  currency          String   @default("EUR")
  status            String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, REFUNDED
  type              String   // DEPOSIT, FULL_PAYMENT, PARTIAL_PAYMENT
  method            String?  // CREDIT_CARD, BANK_TRANSFER, PAYPAL, etc.
  
  // Stripe data
  stripePaymentIntentId String?
  stripeChargeId    String?
  stripeRefundId    String?
  
  // Relations
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  userId            String
  user              User @relation(fields: [userId], references: [id])
  
  requestId         String?
  request           AssistanceRequest? @relation(fields: [requestId], references: [id])
  
  quoteId           String?
  quote             Quote? @relation(fields: [quoteId], references: [id])
  
  metadata          String?  // JSON string
  
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model DepositRule {
  id                String   @id @default(uuid())
  name              String
  description       String?
  depositType       String   // FIXED, PERCENTAGE, RANGES
  fixedAmount       Float?
  percentageAmount  Float?
  ranges            String?  // JSON string
  isActive          Boolean  @default(true)
  
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
}

model Notification {
  id                String   @id @default(uuid())
  type              String   // REQUEST_CREATED, QUOTE_RECEIVED, PAYMENT_COMPLETED, etc.
  title             String
  content           String
  isRead            Boolean  @default(false)
  priority          String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  
  // Relations
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  
  senderId          String?
  sender            User? @relation("NotificationSender", fields: [senderId], references: [id])
  
  recipientId       String
  recipient         User @relation("NotificationRecipient", fields: [recipientId], references: [id])
  
  metadata          String?  // JSON string
  
  readAt            DateTime?
  createdAt         DateTime @default(now())

  @@index([organizationId])
  @@index([recipientId])
  @@index([isRead])
}

model Attachment {
  id                String   @id @default(uuid())
  fileName          String
  originalName      String
  filePath          String
  fileType          String
  fileSize          Int
  description       String?
  
  requestId         String
  request           AssistanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  uploadedById      String
  
  createdAt         DateTime @default(now())

  @@index([requestId])
}

model LoginHistory {
  id                String   @id @default(uuid())
  userId            String
  user              User @relation(fields: [userId], references: [id])
  
  ipAddress         String?
  userAgent         String?
  method            String   // LOCAL, GOOGLE, FACEBOOK, etc.
  success           Boolean
  failureReason     String?
  
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Session {
  id        String   @id
  sid       String   @unique
  sess      String   // JSON
  expire    DateTime
  
  @@index([expire])
}
