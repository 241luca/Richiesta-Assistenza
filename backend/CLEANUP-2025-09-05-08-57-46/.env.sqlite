# Backend Environment Variables - SQLite Version for Local Testing
NODE_ENV=development
PORT=3200

# Database - Using SQLite for local development
DATABASE_URL=file:./dev.db

# Redis - Commented out for local testing
# REDIS_URL=redis://localhost:6380
# REDIS_HOST=localhost
# REDIS_PORT=6380

# Frontend URL
FRONTEND_URL=http://localhost:5193
ALLOWED_ORIGINS=http://localhost:5193,http://127.0.0.1:5193

# Session & JWT
SESSION_SECRET=assistenza_secret_key_2024_multi_tenant_secure
JWT_SECRET=assistenza_jwt_secret_2024_secure_key
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=assistenza_jwt_refresh_secret_2024_secure
JWT_REFRESH_EXPIRE=30d

# 2FA Secret
TWO_FACTOR_APP_NAME=Sistema Richiesta Assistenza

# API Keys (da configurare con le tue chiavi reali)
OPENAI_API_KEY=your_openai_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
BREVO_API_KEY=your_brevo_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@assistenza.it

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_CREDENTIALS=true
