model ReviewSystemConfig {
  id                         String    @id @default(cuid())
  isEnabled                  Boolean   @default(true)
  anonymousReviews           Boolean   @default(false)
  showLastNameInitial        Boolean   @default(true)
  requireComment             Boolean   @default(false)
  minCommentLength           Int       @default(10)
  maxCommentLength           Int       @default(1000)
  maxDaysToReview            Int       @default(30)
  autoModeration             Boolean   @default(true)
  publicReviews              Boolean   @default(true)
  bannedWords                String[]  @default([])
  contentFilter              Boolean   @default(true)
  requireManualApproval      Boolean   @default(false)
  autoApproveThreshold       Int       @default(3)
  notifyAdminForLowRatings   Boolean   @default(true)
  lowRatingThreshold         Int       @default(2)
  showStarsInName            Boolean   @default(true)
  minReviewsToShowAverage    Int       @default(3)
  defaultSortOrder           String    @default("recent")
  reviewsPerPage             Int       @default(10)
  enableBadges               Boolean   @default(true)
  topRatedThreshold          Float     @default(4.5)
  enableLoyaltyPoints        Boolean   @default(false)
  pointsPerReview            Int       @default(10)
  notifyProfessionalOnReview Boolean   @default(true)
  remindClientAfterDays      Int       @default(3)
  notifyAdminOnProblematic   Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime

  @@index([id])
}

model ReviewExclusion {
  id           String    @id @default(cuid())
  userId       String
  type         String    @default("BOTH")
  reason       String
  excludedBy   String
  isActive     Boolean   @default(true)
  isTemporary  Boolean   @default(false)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}
