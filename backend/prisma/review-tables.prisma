// ============================================
// SISTEMA RECENSIONI - CONFIGURAZIONI AVANZATE
// ============================================

// Configurazione Sistema Recensioni
model ReviewSystemConfig {
  id                          String   @id @default(cuid())
  
  // Generali
  isEnabled                   Boolean  @default(true)
  anonymousReviews            Boolean  @default(false)
  showLastNameInitial         Boolean  @default(true)
  requireComment              Boolean  @default(false)
  minCommentLength            Int      @default(10)
  maxCommentLength            Int      @default(1000)
  maxDaysToReview             Int      @default(30)
  autoModeration              Boolean  @default(true)
  publicReviews               Boolean  @default(true)
  
  // Moderazione
  bannedWords                 String[] @default([])
  contentFilter               Boolean  @default(true)
  requireManualApproval       Boolean  @default(false)
  autoApproveThreshold        Int      @default(3)
  notifyAdminForLowRatings    Boolean  @default(true)
  lowRatingThreshold          Int      @default(2)
  
  // Visualizzazione
  showStarsInName             Boolean  @default(true)
  minReviewsToShowAverage     Int      @default(3)
  defaultSortOrder            String   @default("recent") // recent, helpful, rating_high, rating_low
  reviewsPerPage              Int      @default(10)
  
  // Gamification
  enableBadges                Boolean  @default(true)
  topRatedThreshold           Float    @default(4.5)
  enableLoyaltyPoints         Boolean  @default(false)
  pointsPerReview             Int      @default(10)
  
  // Notifiche
  notifyProfessionalOnReview  Boolean  @default(true)
  remindClientAfterDays       Int      @default(3)
  notifyAdminOnProblematic    Boolean  @default(true)
  
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

// Tipo di esclusione recensioni
enum ReviewExclusionType {
  CLIENT        // Cliente non può lasciare recensioni
  PROFESSIONAL  // Professionista non riceve recensioni
  BOTH          // Entrambi
}

// Esclusioni dal sistema recensioni
model ReviewExclusion {
  id            String               @id @default(cuid())
  userId        String
  type          ReviewExclusionType
  reason        String
  excludedBy    String               // Chi ha escluso (admin ID)
  isTemporary   Boolean              @default(false)
  expiresAt     DateTime?
  isActive      Boolean              @default(true)
  notes         String?
  
  // Relazioni
  user          User                 @relation(fields: [userId], references: [id])
  excludedByUser User                @relation("ExcludedByAdmin", fields: [excludedBy], references: [id])
  
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  
  @@index([userId])
  @@index([type])
  @@index([isActive])
}

// Template risposte recensioni
model ReviewResponseTemplate {
  id            String   @id @default(cuid())
  professionalId String?
  name          String
  category      String   // positive, negative, neutral
  template      String   @db.Text
  isGlobal      Boolean  @default(false) // Disponibile per tutti
  usageCount    Int      @default(0)
  
  // Relazioni
  professional  User?    @relation("ProfessionalResponseTemplates", fields: [professionalId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([professionalId])
  @@index([category])
}

// Badge professionisti
model ProfessionalBadge {
  id            String   @id @default(cuid())
  name          String
  description   String
  icon          String   // Nome icona Heroicons
  color         String   // Colore badge
  criteria      Json     // Criteri per ottenere il badge
  isAutomatic   Boolean  @default(true)
  isActive      Boolean  @default(true)
  priority      Int      @default(0) // Ordine visualizzazione
  
  // Relazioni
  professionals ProfessionalBadgeAssignment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Assegnazione badge a professionisti
model ProfessionalBadgeAssignment {
  id            String   @id @default(cuid())
  professionalId String
  badgeId       String
  earnedAt      DateTime @default(now())
  validUntil    DateTime?
  
  // Relazioni
  professional  User     @relation(fields: [professionalId], references: [id])
  badge         ProfessionalBadge @relation(fields: [badgeId], references: [id])
  
  @@unique([professionalId, badgeId])
  @@index([professionalId])
}

// Analytics Recensioni
model ReviewAnalytics {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date @unique
  totalReviews          Int      @default(0)
  averageRating         Float    @default(0)
  reviewsPerProfessional Float   @default(0)
  reviewRate            Float    @default(0) // % interventi recensiti
  
  // Distribuzione stelle
  stars1Count           Int      @default(0)
  stars2Count           Int      @default(0)
  stars3Count           Int      @default(0)
  stars4Count           Int      @default(0)
  stars5Count           Int      @default(0)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([date])
}
