      updatedMaterial,
      material.isFavorite ? 'Rimosso dai preferiti' : 'Aggiunto ai preferiti'
    ));
  } catch (error) {
    logger.error('Errore toggle preferito:', error);
    return res.status(500).json(ResponseFormatter.error(
      'Errore nel modificare il preferito',
      'TOGGLE_FAVORITE_ERROR'
    ));
  }
});

// POST /api/professional/materials/import - Importa materiali da CSV
router.post('/materials/import', authenticate, upload.single('file'), async (req: any, res: Response) => {
  try {
    const professionalId = req.user.id;
    
    if (!req.file) {
      return res.status(400).json(ResponseFormatter.error(
        'Nessun file caricato',
        'NO_FILE'
      ));
    }
    
    const results: any[] = [];
    const errors: any[] = [];
    let rowNumber = 0;
    
    // Parse CSV
    const stream = fs.createReadStream(req.file.path)
      .pipe(csv())
      .on('data', (data) => {
        rowNumber++;
        
        // Validazione base
        if (!data.code || !data.name || !data.price) {
          errors.push({
            row: rowNumber,
            error: 'Campi obbligatori mancanti'
          });
          return;
        }
        
        results.push({
          professionalId,
          code: data.code,
          name: data.name,
          description: data.description || '',
          unit: data.unit || 'pz',
          defaultQuantity: parseFloat(data.quantity) || 1,
          price: parseFloat(data.price) || 0,
          vatRate: parseInt(data.vatRate) || 22,
          category: data.category || 'generale',
          supplierName: data.supplier || null,
          supplierCode: data.supplierCode || null,
          notes: data.notes || null,
          isFavorite: false,
          usageCount: 0
        });
      })
      .on('end', async () => {
        try {
          // Inserisci materiali validi
          if (results.length > 0) {
            await prisma.professionalMaterial.createMany({
              data: results,
              skipDuplicates: true
            });
          }
          
          // Elimina file temporaneo
          fs.unlinkSync(req.file!.path);
          
          return res.json(ResponseFormatter.success(
            {
              imported: results.length,
              errors: errors.length > 0 ? errors : undefined
            },
            `Importati ${results.length} materiali`
          ));
        } catch (error) {
          logger.error('Errore importazione materiali:', error);
          return res.status(500).json(ResponseFormatter.error(
            'Errore durante l\'importazione',
            'IMPORT_ERROR'
          ));
        }
      })
      .on('error', (error) => {
        logger.error('Errore parsing CSV:', error);
        fs.unlinkSync(req.file!.path);
        return res.status(500).json(ResponseFormatter.error(
          'Errore nel parsing del file CSV',
          'CSV_PARSE_ERROR'
        ));
      });
  } catch (error) {
    logger.error('Errore importazione:', error);
    if (req.file) {
      fs.unlinkSync(req.file.path);
    }
    return res.status(500).json(ResponseFormatter.error(
      'Errore durante l\'importazione',
      'IMPORT_ERROR'
    ));
  }
});

export default router;
