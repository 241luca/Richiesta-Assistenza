// POST /api/professional/materials/:id/toggle-favorite - Toggle preferito
router.post('/materials/:id/toggle-favorite', authenticate, async (req: any, res: Response) => {
  try {
    const professionalId = req.user.id;
    const { id } = req.params;
    
    const material = await prisma.professionalMaterial.findFirst({
      where: {
        id,
        professionalId
      }
    });
    
    if (!material) {
      return res.status(404).json(ResponseFormatter.error(
        'Materiale non trovato',
        'MATERIAL_NOT_FOUND'
      ));
    }
    
    const updatedMaterial = await prisma.professionalMaterial.update({
      where: { id },
